{
  "resourceType": "TestScript",
  "id": "TC-CONF-002",
  "url": "https://github.com/hl7germany/consent-test-suite/TestScript/TC-CONF-002",
  "version": "1.0.0",
  "name": "TC_CONF_002_ValidateMissingPatient",
  "title": "TC-CONF-002: Consent ohne Pflichtfeld schlägt $validate fehl",
  "status": "active",
  "description": "Ein Consent ohne patient-Referenz wird per $validate geprüft. Der Server soll einen Fehler zurückliefern, da patient im MII Broad Consent Profil ein Pflichtfeld ist.",
  "fixture": [
    {
      "id": "fixture-consent-missing-patient",
      "autocreate": false,
      "autodelete": false,
      "resource": {
        "reference": "../../fixtures/invalid/consent-missing-patient.json"
      }
    }
  ],
  "test": [
    {
      "id": "test-01",
      "name": "POST /Consent/$validate ohne patient-Referenz",
      "action": [
        {
          "operation": {
            "type": {
              "system": "http://terminology.hl7.org/CodeSystem/testscript-operation-codes",
              "code": "validate"
            },
            "resource": "Consent",
            "description": "Validierung eines Consent ohne patient-Referenz",
            "accept": "application/fhir+json",
            "contentType": "application/fhir+json",
            "sourceId": "fixture-consent-missing-patient"
          }
        },
        {
          "assert": {
            "description": "HTTP 200 OK oder 422 Unprocessable Entity",
            "responseCode": "200,422",
            "warningOnly": false
          }
        },
        {
          "assert": {
            "description": "Response ist OperationOutcome",
            "resource": "OperationOutcome",
            "warningOnly": false
          }
        },
        {
          "assert": {
            "description": "Mindestens ein Issue vom Typ error – fehlendes Pflichtfeld muss gemeldet werden",
            "expression": "OperationOutcome.issue.where(severity = 'error').count() > 0",
            "warningOnly": false
          }
        }
      ]
    }
  ]
}
